<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Copia este archivo como GoogleService-Info.plist y rellena los valores reales
     obtenidos de Firebase Console → Project Settings → iOS app (PIUMS.PiumsCliente).
     NUNCA subas el archivo real al repositorio (.gitignore ya lo excluye). -->
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>REPLACE_WITH_YOUR_CLIENT_ID.apps.googleusercontent.com</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>com.googleusercontent.apps.REPLACE_WITH_YOUR_CLIENT_ID</string>
	<key>API_KEY</key>
	<string>REPLACE_WITH_YOUR_FIREBASE_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>REPLACE_WITH_YOUR_SENDER_ID</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>PIUMS.PiumsCliente</string>
	<key>PROJECT_ID</key>
	<string>REPLACE_WITH_YOUR_PROJECT_ID</string>
	<key>STORAGE_BUCKET</key>
	<string>REPLACE_WITH_YOUR_PROJECT_ID.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>GOOGLE_APP_ID</key>
	<string>1:SENDER_ID:ios:REPLACE_WITH_YOUR_GOOGLE_APP_ID</string>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
</dict>
</plist>
