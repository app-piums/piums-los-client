<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Ubicación: usada para búsqueda de artistas cercanos y autocompletar ubicación de eventos -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Piums usa tu ubicación para mostrarte artistas disponibles cerca de ti y autocompletar la dirección de tus eventos.</string>

	<!-- App Transport Security: prohibir HTTP explícitamente; solo HTTPS permitido -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>

	<!-- Background modes: remote-notifications permite procesar silent push (content-available:1)
	     para sincronizar contadores de mensajes y notificaciones sin que el usuario abra la app -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notifications</string>
	</array>

	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>Google</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.967320828042-ro3iao8ol9i9tmhhjbf1uqdcjrotq4ii</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
